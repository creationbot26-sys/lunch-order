<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>多國語翻譯與朗讀助手</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes bounce-custom {
            0%, 100% { height: 4px; }
            50% { height: 16px; }
        }
        .voice-anim div {
            width: 3px;
            background-color: #2563eb;
            margin: 0 1px;
            animation: bounce-custom 1s infinite;
        }
        .voice-anim div:nth-child(2) { animation-delay: 0.2s; }
        .voice-anim div:nth-child(3) { animation-delay: 0.4s; }
        .loader {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3498db;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-8 text-slate-900 font-sans">

    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <header class="flex items-center gap-3 mb-8">
            <div class="bg-blue-600 p-2 rounded-xl text-white">
                <i class="fa-solid fa-language text-2xl"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">多國語翻譯助手</h1>
                <p class="text-slate-500 text-sm">支援中、英、法翻譯與語音朗讀</p>
            </div>
        </header>

        <!-- Input Section -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-8 focus-within:ring-2 focus-within:ring-blue-500 transition-all">
            <textarea id="inputText"
                class="w-full p-6 text-lg border-none focus:outline-none min-h-[150px] resize-none"
                placeholder="請輸入想要翻譯的文字..."></textarea>
            <div class="bg-slate-50 px-6 py-3 flex justify-end">
                <button id="translateBtn"
                    class="bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 text-white px-6 py-2 rounded-full font-medium flex items-center gap-2 transition-colors">
                    <span id="btnIcon"><i class="fa-solid fa-paper-plane"></i></span>
                    <span id="btnText">翻譯並轉換</span>
                </button>
            </div>
        </div>

        <!-- Results Grid -->
        <div id="resultsGrid" class="grid md:grid-cols-3 gap-6">
            <!-- zh-TW -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col min-h-[220px]" data-lang="zh-TW">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2 py-1 rounded">繁體中文</span>
                    <div class="flex gap-1">
                        <button onclick="copyText('zh-TW')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all" title="複製">
                            <i class="fa-regular fa-copy" id="copy-icon-zh-TW"></i>
                        </button>
                        <button onclick="playTTS('zh-TW', 'Kore')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all voice-btn" id="voice-btn-zh-TW" title="播放">
                            <i class="fa-solid fa-volume-high"></i>
                        </button>
                    </div>
                </div>
                <div class="flex-grow content-area">
                    <p class="text-slate-300 italic text-sm">等待翻譯...</p>
                </div>
            </div>

            <!-- en-US -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col min-h-[220px]" data-lang="en-US">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2 py-1 rounded">英文</span>
                    <div class="flex gap-1">
                        <button onclick="copyText('en-US')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all" title="複製">
                            <i class="fa-regular fa-copy" id="copy-icon-en-US"></i>
                        </button>
                        <button onclick="playTTS('en-US', 'Puck')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all voice-btn" id="voice-btn-en-US" title="播放">
                            <i class="fa-solid fa-volume-high"></i>
                        </button>
                    </div>
                </div>
                <div class="flex-grow content-area">
                    <p class="text-slate-300 italic text-sm">等待翻譯...</p>
                </div>
            </div>

            <!-- fr-FR -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col min-h-[220px]" data-lang="fr-FR">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2 py-1 rounded">法文</span>
                    <div class="flex gap-1">
                        <button onclick="copyText('fr-FR')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all" title="複製">
                            <i class="fa-regular fa-copy" id="copy-icon-fr-FR"></i>
                        </button>
                        <button onclick="playTTS('fr-FR', 'Charon')" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all voice-btn" id="voice-btn-fr-FR" title="播放">
                            <i class="fa-solid fa-volume-high"></i>
                        </button>
                    </div>
                </div>
                <div class="flex-grow content-area">
                    <p class="text-slate-300 italic text-sm">等待翻譯...</p>
                </div>
            </div>
        </div>

        <footer class="mt-12 text-center text-slate-400 text-sm">
            使用 Gemini 2.5 Flash 提供翻譯與語音服務
        </footer>
    </div>

    <script>
        const apiKey = ""; // 系統自動提供
        const languages = [
            { code: 'zh-TW', prompt: 'Traditional Chinese' },
            { code: 'en-US', prompt: 'English' },
            { code: 'fr-FR', prompt: 'French' }
        ];

        let translationData = {
            'zh-TW': '',
            'en-US': '',
            'fr-FR': ''
        };

        const translateBtn = document.getElementById('translateBtn');
        const inputText = document.getElementById('inputText');

        // 指數退避請求
        async function fetchWithRetry(url, options, retries = 5, backoff = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                return await response.json();
            } catch (error) {
                if (retries > 0) {
                    await new Promise(r => setTimeout(r, backoff));
                    return fetchWithRetry(url, options, retries - 1, backoff * 2);
                }
                throw error;
            }
        }

        async function handleTranslate() {
            const text = inputText.value.trim();
            if (!text) return;

            // UI 狀態：載入中
            translateBtn.disabled = true;
            document.getElementById('btnIcon').innerHTML = '<div class="loader"></div>';
            document.getElementById('btnText').innerText = '翻譯中...';

            languages.forEach(lang => {
                const card = document.querySelector(`[data-lang="${lang.code}"] .content-area`);
                card.innerHTML = `
                    <div class="space-y-2">
                        <div class="h-4 bg-slate-100 rounded w-full animate-pulse"></div>
                        <div class="h-4 bg-slate-100 rounded w-5/6 animate-pulse"></div>
                    </div>`;
            });

            // 併發請求翻譯
            const promises = languages.map(async (lang) => {
                try {
                    const payload = {
                        contents: [{
                            parts: [{ text: `Translate this to ${lang.prompt}. Only return the translation: "${text}"` }]
                        }],
                        systemInstruction: {
                            parts: [{ text: "You are a professional translator." }]
                        }
                    };

                    const data = await fetchWithRetry(
                        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
                        {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        }
                    );

                    const resultText = data.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || "翻譯失敗";
                    translationData[lang.code] = resultText;
                    
                    document.querySelector(`[data-lang="${lang.code}"] .content-area`).innerHTML = 
                        `<p class="text-slate-700 leading-relaxed break-words">${resultText}</p>`;
                } catch (err) {
                    document.querySelector(`[data-lang="${lang.code}"] .content-area`).innerHTML = 
                        `<p class="text-red-500 text-sm">連線失敗，請稍後再試</p>`;
                }
            });

            await Promise.all(promises);

            // 恢復 UI
            translateBtn.disabled = false;
            document.getElementById('btnIcon').innerHTML = '<i class="fa-solid fa-paper-plane"></i>';
            document.getElementById('btnText').innerText = '翻譯並轉換';
        }

        async function playTTS(langCode, voiceName) {
            const text = translationData[langCode];
            if (!text) return;

            const btn = document.getElementById(`voice-btn-${langCode}`);
            const originalHTML = btn.innerHTML;
            
            // UI 狀態：播放中
            btn.innerHTML = `<div class="voice-anim flex items-end h-4 px-1"><div></div><div></div><div></div></div>`;
            btn.classList.add('bg-blue-100', 'text-blue-600');

            try {
                const payload = {
                    contents: [{ parts: [{ text: text }] }],
                    generationConfig: {
                        responseModalities: ["AUDIO"],
                        speechConfig: {
                            voiceConfig: { prebuiltVoiceConfig: { voiceName: voiceName } }
                        }
                    },
                    model: "gemini-2.5-flash-preview-tts"
                };

                const response = await fetchWithRetry(
                    `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`,
                    {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    }
                );

                const base64Audio = response.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
                if (base64Audio) {
                    const audioBlob = pcmToWav(base64Audio, 24000);
                    const audio = new Audio(URL.createObjectURL(audioBlob));
                    audio.onended = () => {
                        btn.innerHTML = originalHTML;
                        btn.classList.remove('bg-blue-100', 'text-blue-600');
                    };
                    audio.play();
                } else {
                    throw new Error("No audio data");
                }
            } catch (err) {
                console.error(err);
                btn.innerHTML = originalHTML;
                btn.classList.remove('bg-blue-100', 'text-blue-600');
            }
        }

        function pcmToWav(base64Data, sampleRate) {
            const byteCharacters = atob(base64Data);
            const buffer = new ArrayBuffer(byteCharacters.length);
            const view = new Uint8Array(buffer);
            for (let i = 0; i < byteCharacters.length; i++) {
                view[i] = byteCharacters.charCodeAt(i);
            }

            const wavHeader = new ArrayBuffer(44);
            const headerView = new DataView(wavHeader);
            const writeString = (offset, string) => {
                for (let i = 0; i < string.length; i++) {
                    headerView.setUint8(offset + i, string.charCodeAt(i));
                }
            };

            writeString(0, 'RIFF');
            headerView.setUint32(4, 36 + buffer.byteLength, true);
            writeString(8, 'WAVE');
            writeString(12, 'fmt ');
            headerView.setUint32(16, 16, true);
            headerView.setUint16(20, 1, true); // PCM
            headerView.setUint16(22, 1, true); // Mono
            headerView.setUint32(24, sampleRate, true);
            headerView.setUint32(28, sampleRate * 2, true);
            headerView.setUint16(32, 2, true);
            headerView.setUint16(34, 16, true);
            writeString(36, 'data');
            headerView.setUint32(40, buffer.byteLength, true);

            return new Blob([wavHeader, buffer], { type: 'audio/wav' });
        }

        function copyText(langCode) {
            const text = translationData[langCode];
            if (!text) return;

            const el = document.createElement('textarea');
            el.value = text;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            const icon = document.getElementById(`copy-icon-${langCode}`);
            icon.className = 'fa-solid fa-check text-green-500';
            setTimeout(() => {
                icon.className = 'fa-regular fa-copy';
            }, 2000);
        }

        translateBtn.addEventListener('click', handleTranslate);
    </script>
</body>
</html>
